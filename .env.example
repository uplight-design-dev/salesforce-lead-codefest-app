# App URL (used for OAuth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Salesforce OAuth (server-side only — never expose CLIENT_SECRET to the browser)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3000/api/salesforce/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Salesforce Report IDs (Analytics API)
# [SDR] 2026-Engaged Contacts — https://uplight.lightning.force.com/lightning/r/Report/00OV1000002MCKjMAO/view
SALESFORCE_ENGAGED_CONTACTS_REPORT_ID=00OV1000002MCKjMAO
# Optional aliases / additional reports
SALESFORCE_LEADS_REPORT_ID=
SALESFORCE_PIPELINE_REPORT_ID=
SALESFORCE_TEAM_REPORT_ID=

# Google Analytics 4 (uplight.com usage — server-side service account)
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CLIENT_EMAIL=
GOOGLE_ANALYTICS_PRIVATE_KEY=
